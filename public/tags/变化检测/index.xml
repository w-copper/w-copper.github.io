      </tr>
      <tr>
          <td><strong>作者</strong></td>
          <td>Wenyuan Li, Shunlin Liang, Keyan Chen, Yongzhe Chen, Han Ma, Jianglei Xu, Yichuan Ma, Shikang Guan, Husheng Fang, Zhenwei Shi</td>
      </tr>
      <tr>
          <td><strong>机构</strong></td>
          <td>香港大学、北京航空航天大学等</td>
      </tr>
