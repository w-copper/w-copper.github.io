          <td><strong>发表时间</strong></td>
          <td>2025年5月</td>
      </tr>
      <tr>
          <td><strong>arXiv</strong></td>
          <td><a href="https://arxiv.org/abs/2505.21357" target="_blank" rel="noopener noreferrer">2505.21357</a></td>
