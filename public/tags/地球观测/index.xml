          <td>Liang Yao, Fan Liu, Delong Chen, Chuanyi Zhang, Yijun Wang, Ziyun Chen, Wei Xu, Shimin Di 等</td>
      </tr>
      <tr>
          <td><strong>发表</strong></td>
          <td>ACM Multimedia 2025 (Oral Presentation)</td>
      </tr>
