          <td>PyTorch + PyTorch Lightning</td>
      </tr>
      <tr>
          <td><strong>骨干网络</strong></td>
          <td>SAM ViT-B</td>
      </tr>
      <tr>
          <td><strong>训练</strong></td>
          <td>WandB 日志</td>
      </tr>
      <tr>
          <td><strong>推理</strong></td>
          <td>ONNX 导出支持</td>
      </tr>
  </tbody>
</table>
