          <td>React + Cesium + Tailwind CSS + Vite</td>
      </tr>
      <tr>
          <td><strong>后端</strong></td>
          <td>FastAPI + SQLAlchemy</td>
      </tr>
      <tr>
          <td><strong>数据库</strong></td>
          <td>PostgreSQL + PostGIS</td>
      </tr>
      <tr>
          <td><strong>缓存</strong></td>
